# ─────────────────────────────────────────────────────────────────────
# Variabile pentru Dokploy → serviciul Compose → tab "Environment".
# Copiază conținutul aici, înlocuiește valorile, NU comita versiunea reală.
# Generează secretele: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────

# ── Postgres (rulează în stack) ──
POSTGRES_USER=medusa
POSTGRES_PASSWORD=schimba-ma-parola-tare
POSTGRES_DB=onlybestdevice

# ── Secrete Medusa (obligatorii) ──
JWT_SECRET=genereaza-cu-openssl-rand-base64-32
COOKIE_SECRET=genereaza-cu-openssl-rand-base64-32

# ── URL-uri / CORS (obligatorii) — pune domeniile tale reale ──
# Backend-ul (admin + API). Trebuie să fie URL-ul public al acestui serviciu.
MEDUSA_BACKEND_URL=https://api.domeniul-tau.ro
# Domeniul storefront-ului (Vercel).
STORE_CORS=https://onlybestdevice.ro,https://www.onlybestdevice.ro
# Admin-ul e servit de pe backend.
ADMIN_CORS=https://api.domeniul-tau.ro
# Auth acceptă atât storefront cât și admin.
AUTH_CORS=https://api.domeniul-tau.ro,https://onlybestdevice.ro,https://www.onlybestdevice.ro

# ── Admin bootstrap (opțional) — creează userul de admin la prima pornire ──
CREATE_ADMIN_EMAIL=office@danovicidesign.com
CREATE_ADMIN_PASSWORD=schimba-ma-dupa-primul-login

# ── Object storage S3 / Hetzner (opțional, recomandat pt. imagini produse) ──
# Dacă le lași goale, fișierele se scriu în volumul backend_static.
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=

# ── Stripe (opțional) ──
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend email (opțional) ──
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
